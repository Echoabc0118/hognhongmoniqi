# Database
# Required by Drizzle, database scripts, leaderboard, auth, blog, and game records.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Coze SDK
# Required by the current LLM and TTS routes that use coze-coding-dev-sdk.
COZE_WORKLOAD_IDENTITY_API_KEY="replace-with-your-coze-workload-identity-api-key"
COZE_INTEGRATION_BASE_URL="https://integration.coze.cn"
COZE_INTEGRATION_MODEL_BASE_URL="https://integration.coze.cn/api/v3"

# Runtime
# Optional. Used by src/server.ts and layout/dev behavior.
COZE_PROJECT_ENV="DEV"
HOSTNAME="localhost"
PORT="5000"

# Sharing
# Optional. Used when rendering generated game result cards.
COZE_PROJECT_DOMAIN_DEFAULT="http://localhost:5000"

# Supabase
# Optional in the current app flow. Kept here because a Supabase helper exists.
COZE_SUPABASE_URL=""
COZE_SUPABASE_ANON_KEY=""
COZE_SUPABASE_SERVICE_ROLE_KEY=""
